# Copy to .env and fill in real values. .env is gitignored.

POSTGRES_DB=restaurant_pos
POSTGRES_USER=pos_user
POSTGRES_PASSWORD=change-me

# Must be overridden with a real secret outside of local dev.
JWT_SECRET=change-me
UPLOAD_DIR=uploads
TAX_RATE=0.10
RESTAURANT_NAME=Malantang Restaurant

# First-boot admin account (see backend AdminSeeder). Only used if no
# admin exists yet — safe to leave as-is after the first deploy.
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@restaurant-pos.local
ADMIN_PASSWORD=change-me
